{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://npdev.local/schema/manifest.schema.json",
  "title": "NPDev Sample Manifest",
  "type": "object",
  "required": [
    "sampleId",
    "sampleName",
    "category",
    "description",
    "primaryFlows"
  ],
  "properties": {
    "sampleId": {
      "type": "string",
      "minLength": 1
    },
    "sampleName": {
      "type": "string",
      "minLength": 1
    },
    "category": {
      "type": "string",
      "minLength": 1
    },
    "description": {
      "type": "string",
      "minLength": 1
    },
    "primaryFlows": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "ownedConcepts": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "verificationTargets": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      }
    }
  },
  "additionalProperties": true
}
