{
  "schemaVersion": "npdev-static-generator-artifact-bundle.v4",
  "project": {
    "name": "Clinic Appointment Manager",
    "scenarioId": "clinic-appointment-manager",
    "objective": "Receptionists schedule appointments and inspect runtime evidence.",
    "assumptions": [
      "This fixture is intentionally near-valid and should fail only for apiKey and date function validation."
    ],
    "warnings": []
  },
  "artifacts": [
    {
      "path": "config.json",
      "content": {
        "$schema": "..\\..\\NPDevContract\\schemas\\config.schema.json",
        "configVersion": "1.0",
        "scenario": {
          "name": "clinic-appointment-manager",
          "description": "Near-valid fixture for Web Checkpoint 004D.",
          "outputRoot": "..\\Output"
        },
        "generator": {
          "failIfModelMissing": true,
          "failIfConfigMissing": true,
          "cleanOutputBeforeGenerate": true,
          "emitPluginAssets": true,
          "emitRuntimeAssets": true,
          "emitUiAssets": true
        },
        "bootstrap": {
          "root": "..\\..\\NPDevRuntimeHost",
          "mergeStrategy": "clean-copy"
        },
        "artifact": {
          "root": "..\\Output\\ArtifactNP",
          "generatedFolderName": "npdev-generated",
          "libsFolderName": "libs",
          "metaFolderName": "npdev-meta"
        },
        "finalExec": {
          "root": "..\\Output\\App",
          "deleteBeforeMount": true
        },
        "database": {
          "provider": "docker-postgres",
          "host": "localhost",
          "port": 5432,
          "database": "clinic_appointment_manager",
          "username": "finalexec",
          "password": "finalexec",
          "adminDatabase": "postgres",
          "resetMode": "reset",
          "containerName": "npdev-clinic-appointment-manager"
        },
        "runtime": {
          "springProfile": "dev,step0,trial",
          "serverPort": 8083,
          "javaArgs": [],
          "gradleTask": "bootRun"
        },
        "trialDefaults": {
          "apiKey": "YOUR_API_KEY_HERE",
          "recommendedProfiles": "dev,step0,trial",
          "runtimeUrl": "http://localhost:8083/",
          "databaseMode": "step0-h2",
          "pluginDiscoveryMode": "filesystem-folder",
          "pluginPackageDirectory": "./npdev-generated/src/main/resources/npdev/plugin-packages"
        }
      }
    },
    {
      "path": "model.json",
      "content": {
        "$schema": "contracts/model.schema.json",
        "namespace": "trial.clinicappointmentmanager",
        "dslVersion": "1.0.0",
        "version": "1.0",
        "concepts": [
          {
            "name": "Appointment",
            "fields": [
              {
                "name": "id",
                "type": "uuid",
                "id": true,
                "required": true
              },
              {
                "name": "patientId",
                "type": "uuid",
                "required": true,
                "ui": {
                  "label": "Patient ID",
                  "widget": "text"
                }
              },
              {
                "name": "doctorId",
                "type": "uuid",
                "required": true,
                "ui": {
                  "label": "Doctor ID",
                  "widget": "text"
                }
              },
              {
                "name": "appointmentDate",
                "type": "date",
                "required": true,
                "ui": {
                  "label": "Appointment Date",
                  "widget": "date"
                }
              },
              {
                "name": "status",
                "type": "string",
                "required": true,
                "ui": {
                  "label": "Status",
                  "widget": "text"
                }
              }
            ],
            "invariants": [
              {
                "name": "AppointmentDateRequired",
                "expr": "appointmentDate != null"
              },
              {
                "name": "AppointmentDateFuture",
                "expr": "appointmentDate >= date('today')"
              }
            ]
          }
        ],
        "capabilities": [
          {
            "name": "persistence",
            "type": "PersistenceCapability",
            "operations": [
              "save"
            ]
          },
          {
            "name": "eventBus",
            "type": "EventBusCapability",
            "operations": [
              "emitEvent"
            ]
          }
        ],
        "bindings": [
          {
            "capability": "persistence",
            "adapter": "repository"
          },
          {
            "capability": "eventBus",
            "adapter": "inproc"
          }
        ],
        "events": [
          {
            "name": "AppointmentScheduledEvent",
            "payload": [
              {
                "name": "id",
                "type": "uuid"
              }
            ]
          }
        ],
        "flows": [
          {
            "name": "ScheduleAppointment",
            "input": {
              "concept": "Appointment",
              "mode": "create"
            },
            "steps": [
              {
                "name": "validate-input",
                "type": "enforceInvariants",
                "scope": "Appointment",
                "invariants": [
                  "AppointmentDateRequired",
                  "AppointmentDateFuture"
                ]
              },
              {
                "name": "save-record",
                "type": "capabilityCall",
                "cap": "persistence",
                "op": "save",
                "args": [
                  "$input"
                ],
                "out": "$savedAppointment"
              },
              {
                "name": "emit-event",
                "type": "emitEvent",
                "event": "AppointmentScheduledEvent",
                "from": "$savedAppointment"
              },
              {
                "name": "return-record",
                "type": "return",
                "value": "$savedAppointment"
              }
            ]
          }
        ]
      }
    },
    {
      "path": "manifest.json",
      "content": {
        "sampleId": "clinic-appointment-manager",
        "sampleName": "Clinic Appointment Manager",
        "category": "safe-beta0-web-generated",
        "description": "Receptionists schedule appointments for patients and doctors.",
        "primaryFlows": [
          "ScheduleAppointment"
        ],
        "ownedConcepts": [
          "Appointment"
        ],
        "verificationTargets": [
          "GET /api/flows",
          "POST /api/flows/ScheduleAppointment/execute",
          "GET /api/audit",
          "GET /api/correlations/{correlationId}"
        ],
        "complexity": "simple",
        "mainFlow": "ScheduleAppointment",
        "features": [
          "concept",
          "invariants",
          "persistence",
          "event",
          "trace"
        ],
        "inputFiles": [
          "input/example-request.json"
        ],
        "walkthrough": [
          "Run NPDevGenerator with the artifact bundle.",
          "POST the example request to /api/flows/ScheduleAppointment/execute."
        ],
        "expectedOutcomes": [
          "The appointment is validated, persisted, and returned.",
          "Future-date validation is documented as a Safe Beta0 limitation."
        ]
      }
    },
    {
      "path": "expected-behavior.md",
      "content": "# Expected Behavior\n\n- `ScheduleAppointment` accepts a valid appointment request.\n- The runtime validates required appointment date and IDs.\n- Future-date enforcement is documented as a Safe Beta0 limitation.\n"
    },
    {
      "path": "expected-endpoints.md",
      "content": "# Expected Endpoints\n\n- `GET /api/flows`\n- `POST /api/flows/ScheduleAppointment/execute`\n- `GET /api/audit`\n- `GET /api/correlations/{correlationId}`\n"
    },
    {
      "path": "generation-notes.md",
      "content": "# Generation Notes\n\nThis fixture is expected to fail until `trialDefaults.apiKey` is repaired to `dev-key` and `AppointmentDateFuture` is removed or converted to documentation.\n"
    },
    {
      "path": "input/example-request.json",
      "content": {
        "id": "00000000-0000-0000-0000-000000000001",
        "patientId": "00000000-0000-0000-0000-000000000101",
        "doctorId": "00000000-0000-0000-0000-000000000201",
        "appointmentDate": "2026-06-01",
        "status": "scheduled"
      }
    }
  ],
  "qualityGates": {
    "validationMode": "lightweight-contract-validation",
    "requiredArtifacts": [
      "config.json",
      "model.json",
      "manifest.json",
      "expected-behavior.md",
      "expected-endpoints.md",
      "generation-notes.md"
    ],
    "recommendedArtifacts": [
      "input/example-request.json"
    ],
    "safeBeta0Restrictions": [
      "No real secrets.",
      "No function calls in invariant expressions."
    ],
    "missingInformation": [],
    "riskNotes": [
      "Future-date validation should be handled outside model.json in Safe Beta0."
    ]
  }
}
