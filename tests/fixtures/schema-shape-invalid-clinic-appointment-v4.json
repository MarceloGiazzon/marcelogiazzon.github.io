                "type": "string",
                "required": true,
                "ui": {
                  "label": "Status",
                  "widget": "text"
                }
              }
            ],
            "invariants": [
              {
                "name": "AppointmentStatusAllowed",
                "expr": "['scheduled', 'completed', 'cancelled'].includes(status)"
              }
            ]
          }
        ],
        "capabilities": [
