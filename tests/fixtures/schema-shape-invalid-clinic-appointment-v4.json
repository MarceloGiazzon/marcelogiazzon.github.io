                "type": "uuid"
              }
            ]
          }
        ],
        "flows": [
          {
            "name": "ScheduleAppointment",
            "concept": "Appointment",
            "input": {
              "patientId": {
                "type": "uuid",
                "required": true
              },
              "doctorId": {
                "type": "uuid",
                "required": true
              },
              "status": {
                "type": "string",
                "required": true
              }
            },
            "steps": [
              {
                "name": "validate-input",
                "type": "enforceInvariants",
                "concept": "Appointment",
                "invariants": [
                  "AppointmentStatusAllowed"
                ]
              },
              {
                "name": "save-record",
                "type": "capabilityCall",
                "capability": "persistence",
                "operation": "save",
                "map": {
                  "entity": "$input"
                }
              },
              {
                "name": "return-record",
                "type": "return",
                "map": {
                  "appointment": "$saved"
                }
              }
            ]
          }
        ]
